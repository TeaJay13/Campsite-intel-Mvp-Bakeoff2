---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { fetchTrails } from "../../services/trails.service.js";

const searchQuery = Astro.url.searchParams.get("q") ?? "";
const selectedDifficulty = Astro.url.searchParams.get("difficulty") ?? "";
let data = { items: [], pagination: { page: 1, totalPages: 1, total: 0 } };
let loadError = "";

try {
  data = await fetchTrails({
    q: searchQuery,
    difficulty: selectedDifficulty,
    page: 1,
    limit: 20
  });
} catch (error) {
  loadError = error.message ?? "Failed to load trails";
}
---

<BaseLayout title="Trails">
  <section class="panel">
    <h1>Browse Trails</h1>

    <form method="get" action="/trails" class="search-form">
      <label for="q">Search by name or location</label>
      <div class="field-row">
        <input id="q" name="q" value={searchQuery} placeholder="Try Pine or Cedar" />
        <select id="difficulty" name="difficulty" aria-label="Filter by difficulty">
          <option value="">All difficulties</option>
          <option value="easy" selected={selectedDifficulty === "easy"}>Easy</option>
          <option value="moderate" selected={selectedDifficulty === "moderate"}>Moderate</option>
          <option value="hard" selected={selectedDifficulty === "hard"}>Hard</option>
        </select>
        <button type="submit">Search</button>
      </div>
    </form>

    {loadError ? (
      <p class="error">{loadError}</p>
    ) : data.items.length === 0 ? (
      <div class="empty-state">
        <p>No trails matched your filters.</p>
        <p>Try another search term or difficulty.</p>
      </div>
    ) : (
      <ul class="trail-list">
        {data.items.map((trail) => (
          <li>
            <a href={`/trails/${trail._id}`}>
              <h2>{trail.name}</h2>
              <p>{trail.location}</p>
              <p>
                {trail.difficulty} · {trail.distanceKm} km · +{trail.elevationGainM} m
              </p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  h1 {
    margin: 0 0 1rem;
  }

  .search-form {
    margin-bottom: 1.1rem;
    background: #f8faf6;
    border: 1px solid #d7dfd7;
    border-radius: 12px;
    padding: 0.8rem;
  }

  .field-row {
    display: flex;
    gap: 0.55rem;
    margin-top: 0.45rem;
  }

  input {
    flex: 1;
    min-height: 2.4rem;
    padding: 0.55rem 0.75rem;
    border-radius: 8px;
    border: 1px solid #c7d5c7;
  }

  select {
    min-height: 2.4rem;
    padding: 0.55rem 0.75rem;
    border-radius: 8px;
    border: 1px solid #c7d5c7;
    background: #fff;
    color: #1f2a1f;
  }

  input:focus {
    border-color: #2f6b3e;
    outline: 2px solid rgba(47, 107, 62, 0.2);
    outline-offset: 1px;
  }

  select:focus {
    border-color: #2f6b3e;
    outline: 2px solid rgba(47, 107, 62, 0.2);
    outline-offset: 1px;
  }

  button {
    min-height: 2.4rem;
    padding: 0.6rem 0.9rem;
    border: 0;
    border-radius: 8px;
    background: #245d39;
    color: #fff;
    font-weight: 700;
  }

  .trail-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.8rem;
  }

  .trail-list a {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid #d7dfd7;
    border-radius: 12px;
    padding: 0.9rem;
    background: #fff;
    transition: transform 0.16s ease, border-color 0.16s ease, box-shadow 0.16s ease;
  }

  .trail-list a:hover {
    transform: translateY(-1px);
    border-color: #2f6b3e;
    box-shadow: 0 8px 18px rgba(36, 93, 57, 0.1);
  }

  .trail-list h2 {
    margin: 0 0 0.3rem;
    color: #234a2d;
    font-size: 1.1rem;
  }

  .trail-list p {
    margin: 0.15rem 0;
    color: #3c4f3f;
  }

  .error {
    color: #8d2222;
    font-weight: 600;
  }

  .empty-state {
    border: 1px dashed #b8c8b8;
    border-radius: 10px;
    padding: 0.9rem;
    background: #f9fbf9;
  }

  @media (max-width: 640px) {
    .field-row {
      flex-direction: column;
    }

    select,
    button {
      width: 100%;
    }
  }
</style>
